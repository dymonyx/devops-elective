{
    "ociVersion": "1.3.0",
    "process": {
        "cwd": "/root",
        "args": [
            "/bin/sh",
            "-c",
            "hostname && echo $$ && ps"
        ]
    },
    "root": {
        "path": "alpine-rootfs",
        "readonly": true
    },
    "hostname": "isolated_agonek",
    "linux": {
        "namespaces": [
            {
                "type": "pid"
            },
            {
                "type": "mount"
            },
            {
                "type": "uts"
            }
        ]
    }
}